<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="$(find robot_description)/urdf/properties.xacro"/>


    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.4 0.4 0.06" />
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual> 
    </link>

    <link name="motorX_link">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.15"/> 
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="blue" />
        </visual>
    </link>

    <link name="motorY_link">
        <visual>
            <geometry>
                <cylinder radius="0.05" length="0.15"/> 
            </geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="yellow" />
        </visual>
    </link>

    <joint name="base_motorX_joint" type="continuous">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="base_link"/>
        <child link="motorX_link"/>
    </joint>

    <joint name="base_motorY_joint" type="continuous">
        <origin xyz="0 0 0" rpy="0 0 0" />
        <parent link="base_link"/>
        <child link="motorY_link"/>
    </joint>

</robot>